<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Cockpit dispatch host app on :3200 (DISPATCH_ENABLED=true inside the
       wrapper). Paths are machine-specific by design: the dispatcher runs on
       the Mini only (spec §11 — no cross-machine dispatch). -->
  <key>Label</key><string>com.cockpit.dispatch-server</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>exec /Users/agentsmyth/workspaces/dev/cockpit/ops/bin/dispatch-server.sh</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>ThrottleInterval</key><integer>30</integer>
  <key>StandardOutPath</key><string>/Users/agentsmyth/Library/Logs/cockpit-dispatch/server.log</string>
  <key>StandardErrorPath</key><string>/Users/agentsmyth/Library/Logs/cockpit-dispatch/server.log</string>
</dict>
</plist>
